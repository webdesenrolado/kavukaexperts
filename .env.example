# === DB ===
DATABASE_URL=postgresql://user:password@host:5432/database

# === Auth ===
# Secret pra assinar JWT — gere com: openssl rand -base64 48
AUTH_SECRET=change-me-to-a-long-random-string

# Permitir cookies sem HTTPS (defina "false" pra produção atrás de Nginx sem SSL)
COOKIE_SECURE=true

# === App ===
NODE_ENV=development
APP_BASE_URL=http://localhost:3355

# === SMTP (email transacional — recovery, boas-vindas) ===
# Sem essas vars, emails são logados no console em dev e descartados em produção.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=noreply@seudominio.com.br
SMTP_PASS=sua-senha-smtp
SMTP_FROM_EMAIL=noreply@seudominio.com.br
SMTP_FROM_NAME=Kavuka Experts
