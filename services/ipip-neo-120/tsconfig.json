{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,
    "declaration": true,
    "types": ["vitest/globals"],
    "paths": {
      "@contract/*": ["../_contract/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*", "../_contract/**/*"],
  "exclude": ["node_modules", "dist"]
}
